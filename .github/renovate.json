{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "schedule": ["before 9am on monday"],
  "lockFileMaintenance": { "enabled": true },
  "packageRules": [
    {
      "description": "Group all non-major dev dependency bumps into one PR to cut noise.",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "dev dependencies (non-major)"
    },
    {
      "description": "Toolchain pins (Supabase CLI, etc.) — keep these as their own clearly labelled PRs since they can move CI behaviour.",
      "matchManagers": ["custom.regex"],
      "addLabels": ["toolchain"]
    }
  ],
  "customManagers": [
    {
      "description": "Pick up any version pinned with an inline `# renovate: datasource=… depName=…` annotation, in any file. Generalises to every third-party control, not just Supabase.",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.+\\.ya?ml$/",
        "/^supabase/config\\.toml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?(?: extractVersion=(?<extractVersion>\\S+))?\\s+[\\w-]+\\s*[:=]\\s*\"?(?<currentValue>[\\w.+-]+)\"?"
      ],
      "extractVersionTemplate": "{{#if extractVersion}}{{{extractVersion}}}{{else}}^v?(?<version>.+)${{/if}}",
      "datasourceTemplate": "{{{datasource}}}",
      "depNameTemplate": "{{{depName}}}",
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ]
}
