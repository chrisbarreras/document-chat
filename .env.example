# ---------------------------------------------------------------------------
# document-chat environment variables
#
# Copy to `.env.local` (gitignored) for local development. The same variables
# go into the Vercel project's Environment Variables settings for the prod /
# preview deployments — see docs/deploy.md for the per-environment matrix.
#
# Tier 0 (the /health + /version hello-world) needs NONE of these — the app
# runs with `pnpm dev` out of the box. From Tier 1 (document chat) onward,
# the unset variables below cause the relevant endpoints to fail loud.
# ---------------------------------------------------------------------------

# --- Supabase (used from Tier 1) -------------------------------------------
# Local values are printed by `pnpm db:start` (wraps `supabase start`).
# Cloud values come from the Supabase dashboard: Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from `supabase start` output>

# Server-only. NEVER expose to the browser; do not prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=<service_role key from `supabase start` output>

# --- Inngest (background jobs — used from Tier 1) --------------------------
# Locally, run `pnpm dev:inngest` (or `pnpm dev:all`) to start the Inngest dev
# server alongside Next. The dev server is unauthenticated, so these keys can
# be left blank in `.env.local` — the SDK only warns. In production (Inngest
# Cloud), set both from the Inngest dashboard.
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# --- OpenAI (embeddings — used from Tier 1) --------------------------------
# Server-only API key used by the ingestion pipeline to embed chunks with
# text-embedding-3-small (1536 dims). Required for the chunking + embedding
# Inngest steps to reach `ready`; without it the document stays in `failed`.
# Get one at https://platform.openai.com/api-keys; set a low monthly cap
# during Tier 0/1 development per architecture.md's cost guardrails.
OPENAI_API_KEY=<sk-... from the OpenAI dashboard>

# --- Anthropic (chat — used from Tier 1) -----------------------------------
# Server-only API key used by the streaming chat endpoint to generate
# answers via Claude (architecture.md picks Claude as the primary LLM).
# Required for POST /api/chats/{id}/messages with Accept: text/event-stream;
# without it the endpoint returns 503 service_unavailable. Get one at
# https://console.anthropic.com/. Set a low monthly cap during Tier 0/1.
ANTHROPIC_API_KEY=<sk-ant-... from the Anthropic dashboard>
# Max output tokens per chat reply (default 4096). Replies stream, so raising
# this is safe; lower it to cap cost. 1024 truncated long multi-doc answers.
# CHAT_MAX_TOKENS=4096

# --- OCR for scanned PDFs --------------------------------------------------
# Scanned / image-only PDFs (no embedded text) are transcribed via OCR before
# chunking. OCR_PROVIDER selects the engine:
#   mistral (default) — dedicated OCR engine; no content filter, transcribes
#                       standardized boilerplate too, cheaper per page. Best for
#                       contract/form corpora. Requires MISTRAL_API_KEY below.
#   claude            — Claude vision; reuses ANTHROPIC_API_KEY above, no new
#                       vendor. NOTE: its output content filter refuses to
#                       reproduce standardized boilerplate verbatim (e.g.
#                       state-mandated consumer-protection notices common in
#                       contracts), so such pages/docs fail. OCR_MODEL overrides
#                       the Claude model (default claude-haiku-4-5).
#   none              — disable OCR; textless PDFs fail fast with a clear reason
# OCR_PROVIDER=mistral
# OCR_MODEL=claude-haiku-4-5   # only applies when OCR_PROVIDER=claude
#
# Required for the default (OCR_PROVIDER=mistral). Get one at
# https://console.mistral.ai/
MISTRAL_API_KEY=<msk-... from the Mistral console>


# --- Build info (optional) -------------------------------------------------
# On Vercel these are provided automatically (VERCEL_ENV, VERCEL_GIT_COMMIT_SHA),
# so /version reports environment + git SHA with no config. Set locally only if
# you want /version to report specific values.
# GIT_SHA=
# BUILT_AT=

# --- Smoke test (post-deploy) ----------------------------------------------
# `scripts/smoke.ts` probes /api/health and /api/version on a deployed URL.
# Set this in the Vercel + GitHub environments where you want the smoke job
# to run; locally you can pass `--base-url` instead.
# SMOKE_BASE_URL=https://your-deployment.vercel.app

# --- Testing (optional) ----------------------------------------------------
# Integration tests (`pnpm --filter web run test:integration`) read Supabase
# values from apps/web/.env.test (gitignored). Generate it after `pnpm db:start`:
#
#   supabase status -o env \
#     --override-name api.url=NEXT_PUBLIC_SUPABASE_URL \
#     --override-name auth.anon_key=NEXT_PUBLIC_SUPABASE_ANON_KEY \
#     --override-name auth.service_role_key=SUPABASE_SERVICE_ROLE_KEY \
#     > apps/web/.env.test
#
# E2E tests target a deployment instead of local `next start` when set:
# E2E_BASE_URL=https://your-preview.vercel.app

# --- Eval harness (nightly real-LLM run only) ------------------------------
# Used by .github/workflows/eval.yml's `eval-live` job. The `eval-mock` job
# that gates every PR needs NONE of these — it runs entirely on canned
# transcripts from packages/eval/fixtures/. Set these as GitHub Actions
# repo secrets, not in `.env.local`, unless you actually want to run the
# live runner against a deployed preview from your machine.
# EVAL_API_BASE_URL=https://your-preview.vercel.app
# EVAL_WORKSPACE_ID=<uuid of the workspace the seeder uses>
# EVAL_DOCUMENT_MAP=<path to the seeder's slug → chunk-uuid JSON map>
